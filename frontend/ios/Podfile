require 'json'
require 'pathname'

require Pod::Executable.execute_command('node', ['-p',
  'require.resolve(
    "react-native/scripts/react_native_pods.rb",
    {paths: [process.argv[1]]},
  )', __dir__]).strip

platform :ios, '16.0'

# 🔥 Enable New Architecture
ENV['RCT_NEW_ARCH_ENABLED'] = '1'

prepare_react_native_project!

target 'LifePulse' do
  config = use_native_modules!

  # 🔥 NitroModules / TurboModules REQUIRED
  pod 'NitroModules', :path => '../node_modules/react-native-nitro-modules'

  # Firebase modular headers
  pod 'GoogleUtilities', :modular_headers => true
  pod 'FirebaseCoreInternal', :modular_headers => true
  pod 'FirebaseCore', :modular_headers => true

  use_react_native!(
    :path => config[:reactNativePath],
    :hermes_enabled => true,
    :new_arch_enabled => true,
    :app_path => "#{Pod::Config.instance.installation_root}/.."
  )

  post_install do |installer|
    react_native_post_install(
      installer,
      config[:reactNativePath],
      :mac_catalyst_enabled => false
    )

    # MapLibre post-install hook
    $MLRN.post_install(installer) if defined?($MLRN)

    # ⚡ Fix QuickCrypto NEON error on Intel Simulator
    installer.pods_project.targets.each do |target|
      target.build_configurations.each do |build_config|
        # Exclude arm64 only for iOS simulator on Intel Macs
        if `uname -m`.strip == "x86_64"
          build_config.build_settings['EXCLUDED_ARCHS[sdk=iphonesimulator*]'] = 'arm64'
        end
      end
    end
  end
end